<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- Camera preview — inset from edges for a framed look -->
    <androidx.camera.view.PreviewView
        android:id="@+id/view_finder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="72dp"
        android:layout_marginBottom="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Camera frame border overlay -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="72dp"
        android:layout_marginBottom="120dp"
        android:background="@drawable/camera_frame_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top nav bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#E60A1628"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Live dot + title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/live_dot"
                android:layout_marginEnd="8dp" />

            <TextView
                android:text="GestureAssist"
                android:textColor="#C8DCF8"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Guide button -->
        <ImageButton
            android:id="@+id/btn_guide"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/nav_btn_bg"
            android:src="@android:drawable/ic_menu_help"
            android:tint="#7AB8FF"
            android:contentDescription="Gesture Guide"
            android:layout_marginEnd="8dp" />

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/nav_btn_bg"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#7AB8FF"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- Bottom action bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="112dp"
        android:background="#E60A1628"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gesture result (emoji + label) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/gesture_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖐️"
                android:textSize="36sp" />

            <TextView
                android:id="@+id/gesture_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show your hand"
                android:textColor="#4DA3FF"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:paddingTop="4dp" />

        </LinearLayout>

        <!-- Flip camera button — professional pill style -->
        <LinearLayout
            android:id="@+id/btn_flip"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/flip_btn_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:tint="#C8DCF8"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flip"
                android:textColor="#C8DCF8"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>